APP_ENV=dev
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000

# Autonomyx Agent Identity System
# Copy to .env and fill in values

# ── LiteLLM Gateway (Server 1) ──────────────────────────────
LITELLM_URL=https://llm.openautonomyx.com
LITELLM_MASTER_KEY=sk-autonomyx-...

# ── Keycloak (Human Auth) ───────────────────────────────────
KEYCLOAK_URL=https://auth.unboxd.cloud
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_REALM=autonomyx

# ── SurrealDB (Agent Store) ─────────────────────────────────
SURREAL_URL=http://surrealdb:8000
SURREAL_NS=autonomyx
SURREAL_DB=agents
SURREAL_USER=root
SURREAL_PASS=

# ── OpenFGA (Relationship Auth) ─────────────────────────────
OPENFGA_URL=http://openfga:8080
OPENFGA_STORE_ID=
OPENFGA_AUTH_MODEL_ID=
OPENFGA_PRESHARED_KEY=

# ── OPA (Policy Engine) ─────────────────────────────────────
OPA_URL=http://opa:8181
OPA_POLICY_PATH=v1/data/autonomyx

# ── VictoriaLogs (Audit Log Sink, Server 1) ─────────────────
VICTORIALOGS_URL=http://51.75.251.56:9428

# ── Webhooks ────────────────────────────────────────────────
WEBHOOK_URLS=

# ── Expiry Worker ───────────────────────────────────────────
EXPIRY_CHECK_INTERVAL=60

# ── Bootstrap Defaults ──────────────────────────────────────
BOOTSTRAP_SPONSOR_ID=system@openautonomyx.com
BOOTSTRAP_TENANT_ID=autonomyx

# ── Infisical (Secret Management) ───────────────────────────
INFISICAL_TOKEN=
INFISICAL_URL=http://51.75.251.56:8080
INFISICAL_ENV=prod
INFISICAL_PATH=/

# ── Gateway Discovery ──────────────────────────────────────
GATEWAY_URL=https://llm.openautonomyx.com
GATEWAY_NAME=Autonomyx Model Gateway
GATEWAY_ORG=OpenAutonomyx
FLOWS_URL=https://flows.openautonomyx.com
MCP_URL=
